{
  "name": "whatsapp-chatbot-demo",
  "version": "1.0.0",
  "license": "MIT",
  "engine": {
    "node": ">=14"
  },
  "scripts": {
    "start": "node index.js",
    "worker": "node worker.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "load-test": "node load-test/run.js"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.3",
    "@ironsoftware/ironpdf": "^2026.1.3",
    "axios": "^1.3.6",
    "bullmq": "^5.7.8",
    "canvas": "^3.2.1",
    "cron": "^4.4.0",
    "dotenv": "^17.3.1",
    "exif-reader": "^2.0.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.5",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.10.0",
    "moment": "^2.29.4",
    "mysql2": "^3.22.0",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.4",
    "pdf-poppler": "^0.2.3",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^5.4.624",
    "sharp": "^0.34.5",
    "twilio": "^5.11.1"
  }
}
